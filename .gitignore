# See http://help.github.com/ignore-files/ for more about ignoring files.

# Dependencies
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs
dist/
declarations/
*.tsbuildinfo
*.js.map

# Test artifacts
test-results/
playwright-report/
coverage/
.nyc_output/
playwright/.cache/

# Package artifacts
*.tgz
*.tar.gz

# Environment files
.env
.env.*
!.env.example
!.env.sample

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*.swn
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# Temporary files
*.tmp
.cache/
.temp/

# Optional npm/yarn cache
.npm/
.eslintcache
.stylelintcache

