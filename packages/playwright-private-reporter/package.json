{
  "name": "@your-org/playwright-private-reporter",
  "version": "0.1.0",
  "private": true,
  "description": "Private Jenkins-first Playwright reporting utilities.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/generateReport.d.ts",
      "default": "./dist/cli/generateReport.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.45.0"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
